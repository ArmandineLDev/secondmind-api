# Serveur
PORT=1974
HOST=0.0.0.0
NODE_ENV=development

# Base de données
DATABASE_URL=postgresql://user:password@localhost:5432/secondmind
DB_POOL_MAX=10

# Auth (Better Auth)
BETTER_AUTH_SECRET=change-me-32-chars-minimum
BETTER_AUTH_URL=http://localhost:1974

# Frontend (pour CORS)
CORS_ORIGIN=http://localhost:3000

# Emails (Brevo)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@ton-domaine.com
BREVO_SENDER_NAME=SecondMind

# Stockage fichiers (Scaleway Object Storage)
SCALEWAY_ACCESS_KEY=
SCALEWAY_SECRET_KEY=
SCALEWAY_BUCKET=secondmind-documents
SCALEWAY_ENDPOINT=https://s3.fr-par.scw.cloud
SCALEWAY_REGION=fr-par
